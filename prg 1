import nltk
from nltk.util import ngrams
from collections import defaultdict, Counter

nltk.download('punkt')
nltk.download('punkt_tab')

data = [
    "thank you for your email",
    "please let me know",
    "looking forward to your response"
]

words = " ".join(data).lower().split()

model = defaultdict(Counter)
for a, b, c in ngrams(words, 3):
    model[(a, b)][c] += 1

text = "thank you"
w1, w2 = text.lower().split()

print("Tokens:", words)
print("\nInput:", text)
print("Predicted next word:", model[(w1, w2)].most_common(1)[0][0])
